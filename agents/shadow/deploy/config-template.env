# ============================================================
# SHADOW FORT CONFIGURATION
# ============================================================
#
# Copy this file to /root/fort/config/ and fill in your values
#
# cp config-template.env /root/fort/config/webhook.env
# nano /root/fort/config/webhook.env
#
# ============================================================

# -----------------------------------------------------------
# DISCORD WEBHOOK (for notifications)
# -----------------------------------------------------------
# How to get: Discord Channel → Settings → Integrations → Webhooks → New Webhook
#
WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# -----------------------------------------------------------
# SHADOW SETTINGS
# -----------------------------------------------------------

# How often to run heartbeat (minutes)
HEARTBEAT_INTERVAL=30

# Maximum attacks to log per day (prevents log overflow)
MAX_DAILY_LOGS=10000

# Auto-block IPs after X attacks
AUTO_BLOCK_THRESHOLD=5

# -----------------------------------------------------------
# BUSINESS SETTINGS (future use)
# -----------------------------------------------------------

# Moltbook API (if available)
# MOLTBOOK_API_KEY=your_key_here

# Stripe for payments (future)
# STRIPE_KEY=your_stripe_key
# STRIPE_WEBHOOK_SECRET=your_webhook_secret

# -----------------------------------------------------------
# ALERT THRESHOLDS
# -----------------------------------------------------------

# Alert on Discord after X unique IPs
ALERT_IP_THRESHOLD=10

# Alert on Discord after X attacks/hour
ALERT_ATTACK_THRESHOLD=50
