#!/bin/bash
# Shadow - SCAR-Protected Autonomous Agent
#
# Commands:
#   ./shadow            - Start interactive session (shows report first)
#   ./shadow daemon     - Start unified daemon (recommended)
#   ./shadow run        - Run single heartbeat (legacy)
#   ./shadow fight      - Run combat simulation
#   ./shadow scan       - Scan lab containers
#   ./shadow gate X     - Test if action X passes SCAR
#   ./shadow pause      - Create pause file (stops all actions)
#   ./shadow resume     - Remove pause file
#   ./shadow status     - Show current state
#   ./shadow logs       - Tail logs
#   ./shadow report     - Show session report
#   ./shadow install    - Add to crontab

cd /home/peace/clawd/agents/shadow

# If no arguments, show report then start interactive
if [ $# -eq 0 ]; then
  echo ""
  bun run engine/session-report.ts 2>/dev/null
  echo ""
  echo "Type './shadow help' for commands"
  exit 0
fi

case "$1" in
  daemon|start)
    bun run engine/shadow-daemon.ts start
    ;;

  run)
    bun run engine/heartbeat.ts
    ;;

  fight|battle)
    bun run engine/shadow-daemon.ts fight
    ;;

  scan)
    bun run engine/shadow-daemon.ts scan
    ;;

  gate)
    bun run engine/shadow-daemon.ts gate "${2:-comment}"
    ;;

  enqueue)
    bun run engine/shadow-daemon.ts enqueue "${2:-heartbeat}"
    ;;

  pause)
    echo "Paused at $(date)" > pause.txt
    echo "Shadow paused. Resume with: ./shadow resume"
    ;;

  resume)
    rm -f pause.txt
    echo "Shadow resumed"
    ;;

  status)
    bun run engine/shadow-daemon.ts status
    echo ""
    echo "=== SYSTEM STATE ==="
    if [ -f pause.txt ]; then
      echo "State: PAUSED"
      cat pause.txt
    else
      echo "State: ACTIVE"
    fi
    echo ""
    if [ -f data/shadow-state.json ]; then
      echo "Shadow stats:"
      cat data/shadow-state.json | head -20
    fi
    ;;

  logs)
    tail -f logs/scar.log
    ;;

  report)
    bun run engine/session-report.ts
    ;;

  install)
    echo "Adding to crontab (every 30 minutes)..."
    (crontab -l 2>/dev/null | grep -v "shadow run"; echo "*/30 * * * * cd /home/peace/clawd/agents/shadow && bun run engine/shadow-daemon.ts enqueue heartbeat >> logs/cron.log 2>&1") | crontab -
    echo "Installed. Check with: crontab -l"
    ;;

  uninstall)
    echo "Removing from crontab..."
    crontab -l 2>/dev/null | grep -v "shadow run" | crontab -
    echo "Uninstalled"
    ;;

  test)
    echo "Testing unified engine..."
    bun run engine/shadow-daemon.ts gate comment
    ;;

  *)
    echo "Shadow - SCAR-Protected Autonomous Agent (Unified Engine)"
    echo ""
    echo "Commands:"
    echo "  ./shadow            Show session report + start interactive"
    echo "  ./shadow daemon     Start unified daemon (runs heartbeats)"
    echo "  ./shadow run        Run single heartbeat (legacy)"
    echo "  ./shadow fight      Run combat simulation"
    echo "  ./shadow scan       Scan lab containers"
    echo "  ./shadow gate X     Test if action X passes SCAR gate"
    echo "  ./shadow enqueue X  Manually enqueue action X"
    echo "  ./shadow report     Show session report"
    echo "  ./shadow pause      Pause all actions"
    echo "  ./shadow resume     Resume actions"
    echo "  ./shadow status     Show current state"
    echo "  ./shadow logs       Tail logs"
    echo "  ./shadow install    Add to crontab (30 min)"
    echo "  ./shadow uninstall  Remove from crontab"
    echo ""
    echo "Unified Engine:"
    echo "  All actions now flow through SCAR-gated loop"
    echo "  See: ~/clawd/engine/ for the unified architecture"
    ;;
esac
